        <mxCell id="y2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Yes - Close punch&#xa;If now &gt; schedule end, cap clock_out_at to ends_at&#xa;Set violation note if capped&#xa;Audit: CLOCK_OUT_WEB" vertex="1">
