          <mxGeometry height="130" width="330" x="1240" y="20" as="geometry" />
        </mxCell>
        <mxCell id="r1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Reject (reason required)&#xa;status=rejected&#xa;rejected_by/rejected_at/reason set&#xa;Audit: SCHEDULE_REJECTED" vertex="1">
          <mxGeometry height="130" width="330" x="1240" y="180" as="geometry" />
